# Postgres
POSTGRES_PASSWORD=changeme

# Get this from @BotFather after creating a new bot
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenGoesHere

# Your Telegram user ID, comma-separated if more than one person should be able to use the bot.
# Leave it set - an empty value disables the access check and opens the bot to everyone.
TELEGRAM_ALLOWED_USER_IDS=50758664

# Random secret passed to Telegram's setWebhook (secret_token=) and verified on
# every incoming webhook call. Generate one, e.g. `openssl rand -hex 32`.
TELEGRAM_WEBHOOK_SECRET=changeme-random-hex

# Token required to read/modify the receipts JSON API (sent as the X-API-Token
# header). The API fails closed: if this is unset, it returns 503.
RECEIPTS_API_TOKEN=changeme-random-hex
